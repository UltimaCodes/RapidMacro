<ui:FluentWindow x:Class="RapidMacro.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:local="clr-namespace:RapidMacro.App"
        mc:Ignorable="d"
        Title="RapidMacro"
        Height="640" Width="1040" MinHeight="520" MinWidth="880"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica">

    <ui:FluentWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <local:EmptyToVisibilityConverter x:Key="EmptyToVis" />
        <local:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis" />
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="RapidMacro" />

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="236" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- ===================== LEFT RAIL ===================== -->
            <Border Grid.Column="0" Background="{StaticResource RmSidebarBrush}">
                <DockPanel>
                    <!-- Brand -->
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="20,6,20,18">
                        <Border Width="36" Height="36" CornerRadius="9" Background="{StaticResource RmAccentBrush}">
                            <ui:SymbolIcon Symbol="Keyboard24" FontSize="20" Foreground="#0B0E12"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="RapidMacro" FontSize="16" FontWeight="Bold" />
                            <TextBlock Text="macro pad" FontSize="11"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </StackPanel>

                    <!-- Footer -->
                    <TextBlock DockPanel.Dock="Bottom" Margin="22,0,0,16" FontSize="11"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                               Text="Phase 1 + 2 · driver-free" />

                    <!-- Navigation -->
                    <StackPanel>
                        <RadioButton x:Name="NavDevices" GroupName="Nav" Style="{StaticResource NavItemStyle}"
                                     IsChecked="True">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Keyboard24" FontSize="18" />
                                <TextBlock Text="Devices" Margin="12,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </RadioButton>
                        <RadioButton x:Name="NavAbout" GroupName="Nav" Style="{StaticResource NavItemStyle}">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Info24" FontSize="18" />
                                <TextBlock Text="About" Margin="12,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </RadioButton>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- ===================== CONTENT ===================== -->
            <Grid Grid.Column="1">

                <!-- DEVICES VIEW -->
                <Grid Margin="28,12,28,24"
                      Visibility="{Binding IsChecked, ElementName=NavDevices, Converter={StaticResource BoolToVis}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Grid Grid.Row="0" Margin="0,0,0,18">
                        <StackPanel>
                            <TextBlock Text="Devices" FontSize="26" FontWeight="Bold" />
                            <TextBlock Margin="0,2,0,0" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       Text="Pick a keyboard to capture and turn into a macro pad. Other keyboards keep typing normally." />
                        </StackPanel>
                        <ui:Button x:Name="RefreshButton" Click="RefreshButton_Click"
                                   HorizontalAlignment="Right" VerticalAlignment="Top"
                                   Icon="{ui:SymbolIcon ArrowSync24}" Content="Refresh" />
                    </Grid>

                    <!-- Body: list + detail -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="360" />
                            <ColumnDefinition Width="24" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Device list -->
                        <DockPanel Grid.Column="0">
                            <TextBlock DockPanel.Dock="Top" Text="DETECTED KEYBOARDS" FontSize="11"
                                       FontWeight="SemiBold" Margin="2,0,0,10"
                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                            <Grid>
                                <ListBox ItemsSource="{Binding Keyboards}"
                                         SelectedItem="{Binding SelectedKeyboard, Mode=TwoWay}"
                                         ItemContainerStyle="{StaticResource DeviceCardStyle}"
                                         Background="Transparent" BorderThickness="0"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0" Width="40" Height="40" CornerRadius="9"
                                                        Background="#1FFFFFFF" Margin="0,0,12,0">
                                                    <ui:SymbolIcon Symbol="Keyboard24" FontSize="20"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Text="{Binding DevicePath}" FontSize="11" Margin="0,2,0,0"
                                                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                               TextTrimming="CharacterEllipsis" />
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <TextBlock VerticalAlignment="Top" Margin="2,4,0,0"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           TextWrapping="Wrap"
                                           Visibility="{Binding Keyboards.Count, Converter={StaticResource EmptyToVis}}"
                                           Text="No keyboards detected. Plug one in and hit Refresh." />
                            </Grid>
                        </DockPanel>

                        <!-- Detail -->
                        <Grid Grid.Column="2">
                            <!-- Placeholder when nothing selected -->
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                        Visibility="{Binding HasSelection, Converter={StaticResource InverseBoolToVis}}">
                                <ui:SymbolIcon Symbol="CursorClick24" FontSize="32" HorizontalAlignment="Center"
                                               Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                                <TextBlock Margin="0,8,0,0" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           Text="Select a keyboard on the left." />
                            </StackPanel>

                            <StackPanel Visibility="{Binding HasSelection, Converter={StaticResource BoolToVis}}">
                                <!-- Capture card -->
                                <ui:Card Margin="0,0,0,16">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                            <TextBlock Text="{Binding SelectedKeyboard.DisplayName}"
                                                       FontSize="18" FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding StatusText}" Margin="0,6,0,0" TextWrapping="Wrap"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right">
                                            <ui:ToggleSwitch IsChecked="{Binding IsCapturing, Mode=TwoWay}"
                                                             IsEnabled="{Binding HasSelection}"
                                                             Content="Capture" />
                                        </StackPanel>
                                    </Grid>
                                </ui:Card>

                                <!-- Live key log -->
                                <Grid Margin="0,0,0,8">
                                    <TextBlock Text="LIVE KEYS" FontSize="11" FontWeight="SemiBold"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                                    <ui:Button Content="Clear" Appearance="Secondary" Padding="10,4"
                                               HorizontalAlignment="Right" Click="ClearButton_Click" />
                                </Grid>
                                <Border Background="{StaticResource RmCardBrush}"
                                        BorderBrush="{StaticResource RmCardBorderBrush}" BorderThickness="1"
                                        CornerRadius="10" Height="300">
                                    <Grid>
                                        <TextBlock Margin="16" VerticalAlignment="Top" TextWrapping="Wrap"
                                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                   Visibility="{Binding KeyLog.Count, Converter={StaticResource EmptyToVis}}"
                                                   Text="Turn on capture, then press keys on that keyboard — they show up here instead of typing into your apps." />
                                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="14,12">
                                            <ItemsControl ItemsSource="{Binding KeyLog}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,0,0,5">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto" />
                                                                <ColumnDefinition Width="Auto" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" Text="{Binding Time}"
                                                                       FontFamily="Consolas" FontSize="12.5" Margin="0,0,12,0"
                                                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                                                            <TextBlock Grid.Column="1" Text="{Binding Glyph}"
                                                                       FontSize="12.5" Margin="0,0,10,0">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Foreground" Value="{DynamicResource TextFillColorTertiaryBrush}" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsDown}" Value="True">
                                                                                <Setter Property="Foreground" Value="{StaticResource RmAccentBrush}" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                            <TextBlock Grid.Column="2" Text="{Binding KeyText}"
                                                                       FontFamily="Consolas" FontSize="12.5" />
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Grid>

                <!-- ABOUT VIEW -->
                <Grid Margin="28,12,28,24" MaxWidth="640" HorizontalAlignment="Left"
                      Visibility="{Binding IsChecked, ElementName=NavAbout, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Text="About" FontSize="26" FontWeight="Bold" Margin="0,0,0,12" />
                        <ui:Card Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="How capture works" FontWeight="SemiBold" Margin="0,0,0,6" />
                                <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           Text="RapidMacro uses the Windows Raw Input API to tell which physical keyboard each keystroke came from, and a low-level keyboard hook to swallow the keys of the captured device before any app sees them. No drivers, no kernel components." />
                            </StackPanel>
                        </ui:Card>
                        <ui:Card>
                            <StackPanel>
                                <TextBlock Text="What's next" FontWeight="SemiBold" Margin="0,0,0,6" />
                                <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           Text="Phase 3 adds the macro engine — bind each captured key to an action (launch app, send a hotkey, type text, media controls), saved as JSON profiles." />
                            </StackPanel>
                        </ui:Card>
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</ui:FluentWindow>
